model estado_compra {
  id_estado_compra Int       @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado    String    @unique(map: "nombre_estado") @db.VarChar(30)
  compras          compras[]
}

model estado_cotizacion {
  id_estado_cotizacion Int          @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado        String       @unique(map: "nombre_estado") @db.VarChar(30)
  cotizacion           cotizacion[]
}

model estado_factura {
  id_estado_factura     Int       @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado_factura String    @unique(map: "nombre_estado_factura") @db.VarChar(50)
  factura               factura[]
}

model estado_orden_venta {
  id_estado_orden_venta Int           @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado         String        @unique(map: "nombre_estado") @db.VarChar(50)
  orden_venta           orden_venta[]
}

model estado_remision_compra {
  id_estado_remision_compra Int               @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado             String            @unique(map: "nombre_estado") @db.VarChar(50)
  remision_compra           remision_compra[]
}

model estado_remision_venta {
  id_estado_remision_venta Int              @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado            String           @unique(map: "nombre_estado") @db.VarChar(50)
  remision_venta           remision_venta[]
}

model estado_traslado {
  id_estado_traslado Int        @id @default(autoincrement()) @db.UnsignedInt
  nombre_estado      String     @unique(map: "nombre_estado") @db.VarChar(30)
  traslado           traslado[]
}

model existencias {
  id_existencia          Int                      @id @default(autoincrement()) @db.UnsignedInt
  id_producto            Int                      @db.UnsignedInt
  id_bodega              Int                      @db.UnsignedInt
  nota                   String?                  @db.VarChar(255)
  cantidad               Decimal                  @default(0.00) @db.Decimal(10, 2)
  fecha_vencimiento      DateTime?                @db.Date
  lote                   String                   @default("") @db.VarChar(50)
  detalle_remision_venta detalle_remision_venta[]
  detalle_traslado       detalle_traslado[]
  bodega                 bodega                   @relation(fields: [id_bodega], references: [id_bodega], map: "fk_existencias_bodega")
  producto               producto                 @relation(fields: [id_producto], references: [id_producto], map: "fk_existencias_producto")

  @@unique([id_producto, id_bodega, lote, fecha_vencimiento], map: "uq_existencias")
  @@index([id_bodega], map: "fk_existencias_bodega")
}

model factura {
  id_factura        Int              @id @default(autoincrement()) @db.UnsignedInt
  codigo_factura    String           @unique(map: "codigo_factura") @db.VarChar(20)
  fecha_factura     DateTime         @db.Date
  fecha_vencimiento DateTime?        @db.Date
  total             Decimal          @db.Decimal(10, 2)
  nota              String?          @db.VarChar(255)
  id_cliente        Int              @db.UnsignedInt
  id_estado_factura Int              @db.UnsignedInt
  cliente           cliente          @relation(fields: [id_cliente], references: [id_cliente], map: "fk_factura_cliente")
  estado_factura    estado_factura   @relation(fields: [id_estado_factura], references: [id_estado_factura], map: "fk_factura_estado")
  pagos_abonos      pagos_abonos[]
  remision_venta    remision_venta[]

  @@index([id_estado_factura], map: "fk_factura_estado")
  @@index([id_cliente], map: "idx_factura_cliente")
  @@index([fecha_factura], map: "idx_factura_fecha")
}

model iva {
  id_iva                  Int                       @id @default(autoincrement()) @db.UnsignedInt
  porcentaje              Decimal                   @unique(map: "porcentaje") @db.Decimal(5, 2)
  detalle_compra          detalle_compra[]
  detalle_cotizacion      detalle_cotizacion[]
  detalle_remision_compra detalle_remision_compra[]
  producto                producto[]
}

model metodo_pago {
  id_metodo     Int            @id @default(autoincrement()) @db.UnsignedInt
  nombre_metodo String         @unique(map: "nombre_metodo") @db.VarChar(100)
  pagos_abonos  pagos_abonos[]
}

model municipios {
  id_municipio     Int           @id @default(autoincrement()) @db.UnsignedInt
  nombre_municipio String        @db.VarChar(100)
  id_departamento  Int           @db.UnsignedInt
  bodega           bodega[]
  cliente          cliente[]
  departamentos    departamentos @relation(fields: [id_departamento], references: [id_departamento], map: "fk_municipio_departamento")
  proveedor        proveedor[]

  @@unique([id_departamento, nombre_municipio], map: "uq_municipio_depto")
}

model orden_venta {
  id_orden_venta        Int                   @id @default(autoincrement()) @db.UnsignedInt
  codigo_orden_venta    String?               @unique(map: "codigo_orden_venta") @db.VarChar(20)
  fecha_creacion        DateTime              @db.Date
  fecha_vencimiento     DateTime?             @db.Date
  descripcion           String?               @db.Text
  id_cliente            Int                   @db.UnsignedInt
  id_bodega             Int                   @db.UnsignedInt
  id_estado_orden_venta Int                   @db.UnsignedInt
  id_termino_pago       Int                   @db.UnsignedInt
  id_usuario            Int                   @db.UnsignedInt
  id_cotizacion         Int?                  @unique(map: "uq_ov_cotizacion") @db.UnsignedInt
  detalle_orden_venta   detalle_orden_venta[]
  bodega                bodega                @relation(fields: [id_bodega], references: [id_bodega], map: "fk_ov_bodega")
  cliente               cliente               @relation(fields: [id_cliente], references: [id_cliente], map: "fk_ov_cliente")
  cotizacion            cotizacion?           @relation(fields: [id_cotizacion], references: [id_cotizacion], map: "fk_ov_cotizacion")
  estado_orden_venta    estado_orden_venta    @relation(fields: [id_estado_orden_venta], references: [id_estado_orden_venta], map: "fk_ov_estado")
  termino_pago          termino_pago          @relation(fields: [id_termino_pago], references: [id_termino_pago], map: "fk_ov_termino")
  usuario               usuario               @relation(fields: [id_usuario], references: [id_usuario], map: "fk_ov_usuario")
  remision_venta        remision_venta[]

  @@index([id_estado_orden_venta], map: "fk_ov_estado")
  @@index([id_termino_pago], map: "fk_ov_termino")
  @@index([id_usuario], map: "fk_ov_usuario")
  @@index([id_bodega], map: "idx_ov_bodega")
  @@index([id_cliente], map: "idx_ov_cliente")
  @@index([fecha_creacion], map: "idx_ov_fecha")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
