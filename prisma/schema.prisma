generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model bodega {
  id_bodega                                   Int                   @id @default(autoincrement()) @db.UnsignedInt
  nombre_bodega                               String                @db.VarChar(100)
  direccion                                   String                @db.VarChar(255)
  id_municipio                                Int                   @db.UnsignedInt
  estado                                      Boolean               @default(true)
  municipios                                  municipios            @relation(fields: [id_municipio], references: [id_municipio], map: "fk_bodega_municipio")
  bodegas_por_usuario                         bodegas_por_usuario[]
  compras                                     compras[]
  cotizacion                                  cotizacion[]
  existencias                                 existencias[]
  orden_venta                                 orden_venta[]
  remision_compra                             remision_compra[]
  roles                                       roles[]
  traslado_traslado_id_bodega_destinoTobodega traslado[]            @relation("traslado_id_bodega_destinoTobodega")
  traslado_traslado_id_bodega_origenTobodega  traslado[]            @relation("traslado_id_bodega_origenTobodega")

  @@index([id_municipio], map: "fk_bodega_municipio")
}

model bodegas_por_usuario {
  id_usuario Int     @db.UnsignedInt
  id_bodega  Int     @db.UnsignedInt
  bodega     bodega  @relation(fields: [id_bodega], references: [id_bodega], map: "fk_bpu_bodega")
  usuario    usuario @relation(fields: [id_usuario], references: [id_usuario], map: "fk_bpu_usuario")

  @@id([id_usuario, id_bodega])
  @@index([id_bodega], map: "fk_bpu_bodega")
}

model categoria_producto {
  id_categoria_producto Int        @id @default(autoincrement()) @db.UnsignedInt
  nombre_categoria      String     @unique(map: "nombre_categoria") @db.VarChar(100)
  estado                Boolean    @default(true)
  producto              producto[]
}

model cliente {
  id_cliente      Int              @id @default(autoincrement()) @db.UnsignedInt
  codigo_cliente  String?          @unique(map: "codigo_cliente") @db.VarChar(20)
  nombre_cliente  String           @db.VarChar(150)
  email           String?          @unique(map: "email") @db.VarChar(100)
  telefono        String?          @db.VarChar(20)
  direccion       String?          @db.VarChar(255)
  num_documento   String           @unique(map: "num_documento") @db.VarChar(50)
  id_tipo_cliente Int              @db.UnsignedInt
  id_municipio    Int              @db.UnsignedInt
  id_tipo_doc     Int              @db.UnsignedInt
  estado          Boolean          @default(true)
  municipios      municipios       @relation(fields: [id_municipio], references: [id_municipio], map: "fk_cliente_municipio")
  tipo_cliente    tipo_cliente     @relation(fields: [id_tipo_cliente], references: [id_tipo_cliente], map: "fk_cliente_tipo_cliente")
  tipo_documento  tipo_documento   @relation(fields: [id_tipo_doc], references: [id_tipo_doc], map: "fk_cliente_tipo_doc")
  cotizacion      cotizacion[]
  factura         factura[]
  orden_venta     orden_venta[]
  remision_venta  remision_venta[]

  @@index([id_municipio], map: "fk_cliente_municipio")
  @@index([id_tipo_cliente], map: "fk_cliente_tipo_cliente")
  @@index([id_tipo_doc], map: "fk_cliente_tipo_doc")
}

model compras {
  id_compra          Int               @id @default(autoincrement()) @db.UnsignedInt
  codigo_compra      String            @unique(map: "codigo_compra") @db.VarChar(20)
  fecha_solicitud    DateTime          @db.Date
  id_proveedor       Int               @db.UnsignedInt
  id_termino_pago    Int               @db.UnsignedInt
  descripcion        String?           @db.Text
  subtotal           Decimal           @default(0.00) @db.Decimal(10, 2)
  total_iva          Decimal           @default(0.00) @db.Decimal(10, 2)
  total              Decimal           @default(0.00) @db.Decimal(10, 2)
  id_estado_compra   Int               @db.UnsignedInt
  id_usuario_creador Int               @db.UnsignedInt
  id_bodega          Int               @db.UnsignedInt
  fecha_entrega      DateTime?         @db.Date
  bodega             bodega            @relation(fields: [id_bodega], references: [id_bodega], map: "fk_compra_bodega")
  estado_compra      estado_compra     @relation(fields: [id_estado_compra], references: [id_estado_compra], map: "fk_compra_estado")
  proveedor          proveedor         @relation(fields: [id_proveedor], references: [id_proveedor], map: "fk_compra_proveedor")
  termino_pago       termino_pago      @relation(fields: [id_termino_pago], references: [id_termino_pago], map: "fk_compra_termino_pago")
  usuario            usuario           @relation(fields: [id_usuario_creador], references: [id_usuario], map: "fk_compra_usuario_creador")
  detalle_compra     detalle_compra[]
  remision_compra    remision_compra[]

  @@index([id_bodega], map: "fk_compra_bodega")
  @@index([id_estado_compra], map: "fk_compra_estado")
  @@index([id_proveedor], map: "fk_compra_proveedor")
  @@index([id_termino_pago], map: "fk_compra_termino_pago")
  @@index([id_usuario_creador], map: "fk_compra_usuario_creador")
  @@index([fecha_solicitud], map: "idx_compras_fecha")
}

model cotizacion {
  id_cotizacion        Int                  @id @default(autoincrement()) @db.UnsignedInt
  codigo_cotizacion    String?              @unique(map: "codigo_cotizacion") @db.VarChar(20)
  fecha                DateTime             @db.Date
  fecha_vencimiento    DateTime             @db.Date
  id_cliente           Int                  @db.UnsignedInt
  id_bodega            Int                  @db.UnsignedInt
  id_usuario_creador   Int                  @db.UnsignedInt
  id_estado_cotizacion Int                  @db.UnsignedInt
  observaciones        String?              @db.VarChar(255)
  bodega               bodega               @relation(fields: [id_bodega], references: [id_bodega], map: "fk_cotizacion_bodega")
  cliente              cliente              @relation(fields: [id_cliente], references: [id_cliente], map: "fk_cotizacion_cliente")
  estado_cotizacion    estado_cotizacion    @relation(fields: [id_estado_cotizacion], references: [id_estado_cotizacion], map: "fk_cotizacion_estado")
  usuario              usuario              @relation(fields: [id_usuario_creador], references: [id_usuario], map: "fk_cotizacion_usuario")
  detalle_cotizacion   detalle_cotizacion[]
  orden_venta          orden_venta?

  @@index([id_estado_cotizacion], map: "fk_cotizacion_estado")
  @@index([id_usuario_creador], map: "fk_cotizacion_usuario")
  @@index([id_bodega], map: "idx_cotizacion_bodega")
  @@index([id_cliente], map: "idx_cotizacion_cliente")
  @@index([fecha], map: "idx_cotizacion_fecha")
}

model departamentos {
  id_departamento     Int          @id @default(autoincrement()) @db.UnsignedInt
  nombre_departamento String       @db.VarChar(100)
  id_pais             Int          @db.UnsignedInt
  paises              paises       @relation(fields: [id_pais], references: [id_pais], map: "fk_departamento_pais")
  municipios          municipios[]

  @@unique([id_pais, nombre_departamento], map: "uq_departamento_pais")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_compra {
  id_compra       Int      @db.UnsignedInt
  id_producto     Int      @db.UnsignedInt
  cantidad        Decimal  @db.Decimal(10, 2)
  precio_unitario Decimal  @db.Decimal(10, 2)
  id_iva          Int      @db.UnsignedInt
  compras         compras  @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade, map: "fk_dc_compra")
  iva             iva      @relation(fields: [id_iva], references: [id_iva], map: "fk_dc_iva")
  producto        producto @relation(fields: [id_producto], references: [id_producto], map: "fk_dc_producto")

  @@id([id_compra, id_producto])
  @@index([id_iva], map: "fk_dc_iva")
  @@index([id_producto], map: "fk_dc_producto")
}

