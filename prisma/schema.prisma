model producto {
  id_producto             Int                       @id @default(autoincrement()) @db.UnsignedInt
  codigo_producto         String?                   @unique(map: "codigo_producto") @db.VarChar(20)
  nombre_producto         String                    @db.VarChar(150)
  descripcion             String?                   @db.VarChar(255)
  codigo_barras           String?                   @unique(map: "codigo_barras") @db.VarChar(50)
  id_categoria_producto   Int                       @db.UnsignedInt
  id_iva                  Int                       @db.UnsignedInt
  estado                  Boolean                   @default(true)
  cod_barras              String?                   @db.VarChar(100)
  detalle_compra          detalle_compra[]
  detalle_cotizacion      detalle_cotizacion[]
  detalle_orden_venta     detalle_orden_venta[]
  detalle_remision_compra detalle_remision_compra[]
  existencias             existencias[]
  categoria_producto      categoria_producto        @relation(fields: [id_categoria_producto], references: [id_categoria_producto], map: "fk_producto_categoria")
  iva                     iva                       @relation(fields: [id_iva], references: [id_iva], map: "fk_producto_iva")

  @@index([id_categoria_producto], map: "fk_producto_categoria")
  @@index([id_iva], map: "fk_producto_iva")
}

model proveedor {
  id_proveedor      Int               @id @default(autoincrement()) @db.UnsignedInt
  codigo_proveedor  String?           @unique(map: "codigo_proveedor") @db.VarChar(20)
  num_documento     String            @unique(map: "num_documento") @db.VarChar(50)
  nombre_empresa    String            @db.VarChar(150)
  email             String?           @unique(map: "email") @db.VarChar(100)
  telefono          String?           @db.VarChar(20)
  direccion         String?           @db.VarChar(255)
  nombre_contacto   String?           @db.VarChar(255)
  id_tipo_proveedor Int               @db.UnsignedInt
  id_tipo_doc       Int               @db.UnsignedInt
  id_municipio      Int               @db.UnsignedInt
  estado            Boolean           @default(true)
  compras           compras[]
  municipios        municipios        @relation(fields: [id_municipio], references: [id_municipio], map: "fk_proveedor_municipio")
  tipo_documento    tipo_documento    @relation(fields: [id_tipo_doc], references: [id_tipo_doc], map: "fk_proveedor_tipo_doc")
  tipo_proveedor    tipo_proveedor    @relation(fields: [id_tipo_proveedor], references: [id_tipo_proveedor], map: "fk_proveedor_tipo_proveedor")
  remision_compra   remision_compra[]

  @@index([id_municipio], map: "fk_proveedor_municipio")
  @@index([id_tipo_doc], map: "fk_proveedor_tipo_doc")
  @@index([id_tipo_proveedor], map: "fk_proveedor_tipo_proveedor")
}

model remision_compra {
  id_remision_compra                                             Int                       @id @default(autoincrement()) @db.UnsignedInt
  codigo_remision_compra                                         String                    @unique(map: "codigo_remision_compra") @db.VarChar(20)
  fecha_creacion                                                 DateTime                  @db.Date
  fecha_vencimiento                                              DateTime?                 @db.Date
  observaciones                                                  String?                   @db.VarChar(255)
  id_compra                                                      Int                       @db.UnsignedInt
  id_proveedor                                                   Int                       @db.UnsignedInt
  id_estado_remision_compra                                      Int                       @db.UnsignedInt
  id_usuario_creador                                             Int                       @db.UnsignedInt
  id_factura                                                     Int?                      @db.UnsignedInt
  firma_digital                                                  Bytes?
  nombre_firmante                                                String?                   @db.VarChar(150)
  fecha_firma                                                    DateTime?                 @db.DateTime(0)
  afecta_existencias                                             Boolean                   @default(false)
  fecha_aplicacion_existencias                                   DateTime?                 @db.DateTime(0)
  id_usuario_aplico_existencias                                  Int?                      @db.UnsignedInt
  id_bodega                                                      Int                       @db.UnsignedInt
  detalle_remision_compra                                        detalle_remision_compra[]
  bodega                                                         bodega                    @relation(fields: [id_bodega], references: [id_bodega], onDelete: NoAction, onUpdate: NoAction, map: "fk_remision_compra_bodega")
  compras                                                        compras                   @relation(fields: [id_compra], references: [id_compra], map: "fk_remision_compra_compra")
  estado_remision_compra                                         estado_remision_compra    @relation(fields: [id_estado_remision_compra], references: [id_estado_remision_compra], map: "fk_remision_compra_estado")
  proveedor                                                      proveedor                 @relation(fields: [id_proveedor], references: [id_proveedor], map: "fk_remision_compra_proveedor")
  usuario                                                        usuario                   @relation(fields: [id_usuario_creador], references: [id_usuario], map: "fk_remision_compra_usuario")
  usuario_remision_compra_id_usuario_aplico_existenciasTousuario usuario?                  @relation("remision_compra_id_usuario_aplico_existenciasTousuario", fields: [id_usuario_aplico_existencias], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_remision_compra_usuario_aplico_existencias")

  @@index([id_estado_remision_compra], map: "fk_remision_compra_estado")
  @@index([id_proveedor], map: "fk_remision_compra_proveedor")
  @@index([id_usuario_creador], map: "fk_remision_compra_usuario")
  @@index([id_compra], map: "idx_remision_compra_compra")
  @@index([fecha_creacion], map: "idx_remision_compra_fecha")
  @@index([id_bodega], map: "idx_remision_compra_bodega")
  @@index([id_usuario_aplico_existencias], map: "idx_remision_compra_usuario_aplico_existencias")
}

model remision_venta {
  id_remision_venta        Int                      @id @default(autoincrement()) @db.UnsignedInt
  codigo_remision_venta    String?                  @unique(map: "codigo_remision_venta") @db.VarChar(20)
  fecha_creacion           DateTime                 @db.Date
  fecha_vencimiento        DateTime?                @db.Date
  observaciones            String?                  @db.VarChar(255)
  id_orden_venta           Int                      @db.UnsignedInt
  id_cliente               Int                      @db.UnsignedInt
  id_estado_remision_venta Int                      @db.UnsignedInt
  id_usuario_creador       Int                      @db.UnsignedInt
  id_factura               Int?                     @db.UnsignedInt
  firma_digital            Bytes?
  nombre_firmante          String?                  @db.VarChar(150)
  fecha_firma              DateTime?                @db.DateTime(0)
  detalle_remision_venta   detalle_remision_venta[]
  cliente                  cliente                  @relation(fields: [id_cliente], references: [id_cliente], map: "fk_rv_cliente")
  estado_remision_venta    estado_remision_venta    @relation(fields: [id_estado_remision_venta], references: [id_estado_remision_venta], map: "fk_rv_estado")
  factura                  factura?                 @relation(fields: [id_factura], references: [id_factura], map: "fk_rv_factura")
  orden_venta              orden_venta              @relation(fields: [id_orden_venta], references: [id_orden_venta], map: "fk_rv_orden")
  usuario                  usuario                  @relation(fields: [id_usuario_creador], references: [id_usuario], map: "fk_rv_usuario")

  @@index([id_cliente], map: "fk_rv_cliente")
  @@index([id_estado_remision_venta], map: "fk_rv_estado")
  @@index([id_factura], map: "fk_rv_factura")
  @@index([id_usuario_creador], map: "fk_rv_usuario")
  @@index([fecha_creacion], map: "idx_rv_fecha")
  @@index([id_orden_venta], map: "idx_rv_orden")
}

model roles {
  id_rol            Int              @id @default(autoincrement()) @db.UnsignedInt
  nombre_rol        String           @unique(map: "nombre_rol") @db.VarChar(50)
  descripcion       String?          @db.VarChar(200)
  estado            Boolean          @default(true)
  id_bodega_default Int?             @db.UnsignedInt
  bodega            bodega?          @relation(fields: [id_bodega_default], references: [id_bodega], map: "fk_roles_bodega_default")
  roles_permisos    roles_permisos[]
  usuario           usuario[]

  @@index([id_bodega_default], map: "fk_roles_bodega_default")
}

model roles_permisos {
  id_rol     Int      @db.UnsignedInt
  id_permiso Int      @db.UnsignedInt
  permisos   permisos @relation(fields: [id_permiso], references: [id_permiso], onDelete: Cascade, map: "fk_rp_permiso")
  roles      roles    @relation(fields: [id_rol], references: [id_rol], onDelete: Cascade, map: "fk_rp_rol")

  @@id([id_rol, id_permiso])
  @@index([id_permiso], map: "fk_rp_permiso")
}

model termino_pago {
  id_termino_pago Int           @id @default(autoincrement()) @db.UnsignedInt
  nombre_termino  String        @unique(map: "nombre_termino") @db.VarChar(100)
  compras         compras[]
  orden_venta     orden_venta[]
}

model tipo_cliente {
  id_tipo_cliente     Int       @id @default(autoincrement()) @db.UnsignedInt
  nombre_tipo_cliente String    @unique(map: "nombre_tipo_cliente") @db.VarChar(50)
  cliente             cliente[]
}

model tipo_documento {
  id_tipo_doc Int         @id @default(autoincrement()) @db.UnsignedInt
  nombre_doc  String      @unique(map: "nombre_doc") @db.VarChar(60)
  cliente     cliente[]
  proveedor   proveedor[]
  usuario     usuario[]
}

model tipo_proveedor {
  id_tipo_proveedor     Int         @id @default(autoincrement()) @db.UnsignedInt
  nombre_tipo_proveedor String      @unique(map: "nombre_tipo_proveedor") @db.VarChar(50)
  proveedor             proveedor[]
}

model traslado {
  id_traslado                               Int                @id @default(autoincrement()) @db.UnsignedInt
  id_bodega_origen                          Int                @db.UnsignedInt
  id_bodega_destino                         Int                @db.UnsignedInt
  fecha_traslado                            DateTime           @db.Date
  nota                                      String?            @db.VarChar(255)
  id_estado_traslado                        Int                @db.UnsignedInt
  id_responsable                            Int?               @db.UnsignedInt
  codigo_traslado                           String?            @unique(map: "codigo_traslado") @db.VarChar(20)
  detalle_traslado                          detalle_traslado[]
  bodega_traslado_id_bodega_destinoTobodega bodega             @relation("traslado_id_bodega_destinoTobodega", fields: [id_bodega_destino], references: [id_bodega], map: "fk_traslado_destino")
  estado_traslado                           estado_traslado    @relation(fields: [id_estado_traslado], references: [id_estado_traslado], map: "fk_traslado_estado")
  bodega_traslado_id_bodega_origenTobodega  bodega             @relation("traslado_id_bodega_origenTobodega", fields: [id_bodega_origen], references: [id_bodega], map: "fk_traslado_origen")
  usuario                                   usuario?           @relation(fields: [id_responsable], references: [id_usuario], map: "fk_traslado_responsable")

  @@index([id_estado_traslado], map: "fk_traslado_estado")
  @@index([id_bodega_destino], map: "idx_traslado_destino")
  @@index([fecha_traslado], map: "idx_traslado_fecha")
  @@index([id_bodega_origen], map: "idx_traslado_origen")
  @@index([id_responsable], map: "fk_traslado_responsable")
}

model usuario {
  id_usuario                                                             Int                   @id @default(autoincrement()) @db.UnsignedInt
  nombre                                                                 String                @db.VarChar(100)
  apellido                                                               String                @db.VarChar(100)
  id_tipo_doc                                                            Int                   @db.UnsignedInt
  num_documento                                                          String                @unique(map: "num_documento") @db.VarChar(20)
  email                                                                  String                @unique(map: "email") @db.VarChar(100)
  contrasena                                                             String                @db.VarChar(255)
  id_rol                                                                 Int                   @db.UnsignedInt
  estado                                                                 Boolean               @default(true)
  telefono                                                               String?               @db.VarChar(30)
  fecha_nacimiento                                                       DateTime?             @db.Date
  img_url                                                                String?               @db.VarChar(500)
  id_genero                                                              Int?                  @db.UnsignedInt
  bodegas_por_usuario                                                    bodegas_por_usuario[]
  compras                                                                compras[]
  cotizacion                                                             cotizacion[]
  orden_venta                                                            orden_venta[]
  remision_compra                                                        remision_compra[]
  remision_compra_remision_compra_id_usuario_aplico_existenciasTousuario remision_compra[]     @relation("remision_compra_id_usuario_aplico_existenciasTousuario")
  remision_venta                                                         remision_venta[]
  traslado                                                               traslado[]
  genero                                                                 genero?               @relation(fields: [id_genero], references: [id_genero], map: "fk_usuario_genero")
  roles                                                                  roles                 @relation(fields: [id_rol], references: [id_rol], map: "fk_usuario_rol")
  tipo_documento                                                         tipo_documento        @relation(fields: [id_tipo_doc], references: [id_tipo_doc], map: "fk_usuario_tipo_doc")

  @@index([id_rol], map: "fk_usuario_rol")
  @@index([id_tipo_doc], map: "fk_usuario_tipo_doc")
  @@index([id_genero], map: "fk_usuario_genero")
}

model genero {
  id_genero     Int       @id @default(autoincrement()) @db.UnsignedInt
  nombre_genero String    @unique(map: "nombre_genero") @db.VarChar(30)
  usuario       usuario[]
}
